{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodouyin.local/schemas/script.schema.json",
  "$comment": "[INPUT]: brief; [OUTPUT]: structured narrative script; [POS]: schemas planning contract; [PROTOCOL]: update this contract, then check CLAUDE.md",
  "title": "Script",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "brief_id", "video_type", "strategy", "title", "logline", "segments", "template_mode", "template_confidence"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "video_type": {
      "type": "string",
      "enum": ["workflow-explainer", "product-demo", "narrative-story", "character-action", "space-tour"]
    },
    "strategy": {
      "type": "string",
      "enum": ["five-beat-short-video", "three-phase-segmented-video", "scene-split-edit-pipeline"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "logline": {
      "type": "string",
      "minLength": 1
    },
    "template_mode": {
      "type": "string"
    },
    "template_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment_id", "purpose", "summary", "emotion", "estimated_seconds"],
        "properties": {
          "segment_id": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "spoken_line": {
            "type": "string"
          },
          "emotion": {
            "type": "string"
          },
          "estimated_seconds": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
