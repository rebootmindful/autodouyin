{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodouyin.local/schemas/seedance-job.schema.json",
  "$comment": "[INPUT]: storyboard and assets; [OUTPUT]: platform-ready generation job; [POS]: schemas generation contract; [PROTOCOL]: update this contract, then check CLAUDE.md",
  "title": "SeedanceJob",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "storyboard_id",
    "duration_seconds",
    "aspect_ratio",
    "mode",
    "global_style_anchor",
    "continuity_locks",
    "negative_constraints",
    "slot_plan",
    "video_type",
    "strategy",
    "prompt_blocks"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "storyboard_id": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 4
    },
    "aspect_ratio": {
      "type": "string",
      "enum": ["9:16", "16:9", "1:1", "4:3", "3:4", "21:9"]
    },
    "mode": {
      "type": "string"
    },
    "global_style_anchor": {
      "type": "string",
      "minLength": 1
    },
    "continuity_locks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "negative_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "slot_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "asset_id", "usage"],
        "properties": {
          "ref": { "type": "string" },
          "asset_id": { "type": "string", "pattern": "^(C|S|P)\\d{2}$" },
          "usage": { "type": "string" }
        }
      }
    },
    "video_type": {
      "type": "string",
      "enum": ["workflow-explainer", "product-demo", "narrative-story", "character-action", "space-tour"]
    },
    "strategy": {
      "type": "string",
      "enum": ["five-beat-short-video", "three-phase-segmented-video", "scene-split-edit-pipeline"]
    },
    "identity_strategy": {
      "type": "string"
    },
    "execution_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "video_type",
        "hard_single_generation_range_seconds",
        "official_ui_recommended_range_seconds",
        "fastest_test_window_seconds",
        "fastest_practical_window_seconds",
        "stable_expression_window_seconds",
        "default_duration_seconds_for_type",
        "max_single_generation_seconds",
        "scene_split_recommended_after_seconds",
        "suggested_split_strategy",
        "requested_duration_seconds"
      ],
      "properties": {
        "video_type": {
          "type": "string",
          "enum": ["workflow-explainer", "product-demo", "narrative-story", "character-action", "space-tour"]
        },
        "hard_single_generation_range_seconds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "official_ui_recommended_range_seconds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "fastest_test_window_seconds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "fastest_practical_window_seconds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "stable_expression_window_seconds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "default_duration_seconds_for_type": {
          "type": "integer",
          "minimum": 1
        },
        "max_single_generation_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "scene_split_recommended_after_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "suggested_split_strategy": {
          "type": "string"
        },
        "requested_duration_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "scene_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_id", "start_second", "end_second", "edit_join"],
        "properties": {
          "scene_id": { "type": "string" },
          "start_second": { "type": "number", "minimum": 0 },
          "end_second": { "type": "number", "exclusiveMinimum": 0 },
          "edit_join": { "type": "string" }
        }
      }
    },
    "prompt_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "block_id",
          "scene_id",
          "mode",
          "start_second",
          "end_second",
          "prompt",
          "image_refs",
          "video_refs",
          "audio_refs"
        ],
        "properties": {
          "block_id": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "start_second": {
            "type": "number",
            "minimum": 0
          },
          "end_second": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "duration_seconds": {
            "type": "integer",
            "minimum": 4,
            "maximum": 15
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "image_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^@图片[1-9]$"
            }
          },
          "video_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^@视频[1-3]$"
            }
          },
          "audio_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^@音频[1-3]$"
            }
          }
        }
      }
    }
  }
}
