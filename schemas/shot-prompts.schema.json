{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodouyin.local/schemas/shot-prompts.schema.json",
  "$comment": "[INPUT]: LLM imagination; [OUTPUT]: Seedance-native shot prompts; [POS]: schemas direct-prompt contract — LLM writes freely, compiler structures; [PROTOCOL]: update then check CLAUDE.md",
  "title": "ShotPrompts",
  "description": "LLM 直出的 Seedance 分镜提示词。每个 shot 是独立的 Seedance prompt，编译器负责结构化、校验和补全技术参数。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "brief_id", "shots"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "brief_id": { "type": "string", "minLength": 1 },
    "generated_by": { "type": "string" },
    "creative_direction": { "type": "string", "description": "一句话创作方向" },
    "director_voice": { "type": "string", "description": "导演之声" },
    "scene_function": { "type": "string", "description": "场景功能: reveal/intimate-dialogue/confrontation/decision/pursuit/comedic-beat/emotional-low/product-hero/transformation/arrival" },
    "intention": { "type": "string", "description": "一句话意图: 这个镜头要让观众感受到什么" },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["shot_id", "start_second", "end_second", "prompt"],
        "properties": {
          "shot_id": { "type": "string", "pattern": "^shot-\\d{2}$" },
          "start_second": { "type": "number", "minimum": 0 },
          "end_second": { "type": "number", "exclusiveMinimum": 0 },
          "prompt": {
            "type": "string",
            "minLength": 1,
            "description": "Seedance 原生提示词。LLM 用 Seedance 视觉语言自由书写——空间、光线、材质、动作、色彩、镜头运动。不需要 --dur --rs --rt 等技术指令，编译器自动追加。"
          },
          "camera_hint": {
            "type": "string",
            "description": "可选的镜头建议，编译器会映射到 camera_codec。如 '中景推进 Z5 Y4 X2 50mm'"
          }
        }
      }
    }
  }
}
